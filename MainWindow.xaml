<Window
    x:Class="PixelPick.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    Title="PixelPick">

    <Grid x:Name="RootGrid" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Three cards -->
        <StackPanel x:Name="CardsPanel" Grid.Row="0" Orientation="Horizontal" Spacing="12" Padding="12,12,12,0" HorizontalAlignment="Left">

            <!-- Color values card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="6">

                    <TextBlock Text="RGB" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RgbValue" Grid.Column="0" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="14" MinWidth="148" TextAlignment="Center"/>
                        <Button x:Name="CopyRgbButton" Grid.Column="1" Margin="4,0,0,0" Click="CopyRgbButton_Click">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        </Button>
                    </Grid>

                    <TextBlock Text="HEX" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HexValue" Grid.Column="0" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="14" MinWidth="148" TextAlignment="Center"/>
                        <Button x:Name="CopyHexButton" Grid.Column="1" Margin="4,0,0,0" Click="CopyHexButton_Click">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        </Button>
                    </Grid>

                    <TextBlock Text="HSL" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HslValue" Grid.Column="0" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="14" MinWidth="148" TextAlignment="Center"/>
                        <Button x:Name="CopyHslButton" Grid.Column="1" Margin="4,0,0,0" Click="CopyHslButton_Click">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Color sample card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sample" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Border Width="112" Height="112" CornerRadius="4" BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <canvas:CanvasControl x:Name="ColorSampleCanvas" Draw="ColorSampleCanvas_Draw"/>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="EditButton" Grid.Column="0" Content="Edit"
                                IsEnabled="False" HorizontalAlignment="Stretch" Click="EditButton_Click"/>
                        <Button x:Name="RevertButton" Grid.Column="2" Content="Revert"
                                IsEnabled="False" HorizontalAlignment="Stretch" Click="RevertButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Zoom card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ZoomLabel" Text="Zoom ×10" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Border Width="112" Height="112" CornerRadius="4" BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <canvas:CanvasControl x:Name="ZoomCanvas" Draw="ZoomCanvas_Draw"/>
                    </Border>
                    <TextBlock x:Name="CoordText" Text="0, 0"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="1" Margin="0,12,0,0" Padding="12,4"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="VersionText"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Ctrl + Space to freeze..."
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Padding="4" Click="HelpButton_Click">
                    <FontIcon Glyph="&#xE946;" FontSize="13"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
